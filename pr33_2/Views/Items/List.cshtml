@using pr33_2.Data.Models
@using pr33_2.Data.Mocks;
@model IEnumerable<Items>
@{
    Layout = "_Layout";
}
<h2>Все предметы</h2>
@{
    foreach(var item in Model)
    {
        <div class="item">
            <img src="@item.Img"/>
            <div class="data">
                <h3>модель: @item.Name</h3>
                <p>цена: @item.Price.ToString()</p>
                <p>категория: @item.category.Name</p>
                <p>описание: @item.Description</p>
            </div>
            
        </div>
    }
}
